# ======================
# OddNoty Environment
# ======================

# --- Database ---
POSTGRES_USER=oddnoty
POSTGRES_PASSWORD=changeme
POSTGRES_DB=oddnoty
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://oddnoty:changeme@postgres:5432/oddnoty

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Data Source API (legacy single-key mode) ---
# Used only when goaledge_keys.yaml is absent.
# When YAML key pool config exists, these are ignored.
DATA_SOURCE=sportmonks
SPORTMONKS_API_KEY=your_sportmonks_api_key_here
THEODDSAPI_KEY=your_theoddsapi_key_here

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Email (optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# --- Worker ---
WORKER_INTERVAL_SECONDS=10
ODDS_MOVEMENT_THRESHOLD_PERCENT=15

# --- Key Pool (multi-provider rotation) ---
# Path to YAML key pool config (relative to worker dir)
KEY_POOL_CONFIG_PATH=goaledge_keys.yaml
# Strategy: reactive, proactive, roundrobin, weighted
ROTATION_STRATEGY=proactive
# Proactive rotation threshold (0.0-1.0)
SAFETY_THRESHOLD=0.85
# Print health dashboard every N cycles (0=disabled)
HEALTH_DASHBOARD_INTERVAL=30
# Use Redis for quota tracking (true=multi-process safe)
USE_REDIS_QUOTA=false
# Per-pillar polling intervals (seconds)
SCORE_POLL_INTERVAL=15
ODDS_POLL_INTERVAL=30

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-this-to-a-random-secret

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
